# 관리자 로그인 비밀번호 (bcrypt 해시 권장, cost=12 이상)
# 평문 비밀번호로 저장하면 타이밍 공격에 제한적 노출됨 — 반드시 bcrypt 해시 사용
# 해시 생성: node -e "require('bcrypt').hash('YOUR_PASSWORD', 12).then(console.log)"
# ⚠️ 중요: 해시의 "$" 문자는 @next/env가 변수로 확장함. 각 $ 앞에 \ 이스케이프 필수
# 예) ADMIN_PASSWORD=\$2b\$12\$abc...
ADMIN_PASSWORD=generate-a-bcrypt-hash-do-not-use-plaintext

# 쿠키 서명용 HMAC 시크릿 (32바이트 이상 암호학적 난수)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET=generate-32-bytes-random-hex-do-not-use-placeholder

# Supabase 설정 (https://supabase.com에서 프로젝트 생성 후 설정하세요)
# 프로젝트 설정 > API > Project URL
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url

# 프로젝트 설정 > API > Project API Keys > anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# 프로젝트 설정 > API > Project API Keys > service_role secret
# ⚠️ 서버 전용 — 절대 NEXT_PUBLIC_ 접두사를 붙이거나 클라이언트에 노출하지 말 것
# 이 키가 설정되면 콘텐츠 저장소가 파일 → Supabase DB로 자동 전환됨 (docs/SETUP_PRODUCTION.md)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Upstash Redis — Rate Limiter 서버리스 공유 (선택)
# 미설정 시 인메모리 폴백으로 동작하나, Vercel 등 서버리스 환경에서는
# 인스턴스 간 공유가 안 되므로 프로덕션에서는 반드시 설정 권장
# 무료 티어: https://console.upstash.com/ → Create Redis Database → REST API 활성화
UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-rest-token

{"screenId":"00852b28e2454f0b9da4ff3d19d8da4d","projectId":"6493943939238031404","htmlContent":"<!DOCTYPE html>\n\n<html lang=\"ko\"><head>\n<meta charset=\"utf-8\"/>\n<meta content=\"width=device-width, initial-scale=1.0\" name=\"viewport\"/>\n<title>Urban Safety Design Center | CCEJ</title>\n<script src=\"https://cdn.tailwindcss.com?plugins=forms,container-queries\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@300;400;500;700;900&amp;family=Public+Sans:wght@400;600;700;800&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<link href=\"https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap\" rel=\"stylesheet\"/>\n<script id=\"tailwind-config\">\n        tailwind.config = {\n            darkMode: \"class\",\n            theme: {\n                extend: {\n                    colors: {\n                        \"tertiary-fixed\": \"#ffdbcb\",\n                        \"inverse-on-surface\": \"#f2f0f0\",\n                        \"tertiary-container\": \"#622600\",\n                        \"error\": \"#ba1a1a\",\n                        \"inverse-surface\": \"#303031\",\n                        \"on-tertiary-fixed-variant\": \"#793100\",\n                        \"on-secondary-fixed-variant\": \"#005312\",\n                        \"on-primary-fixed\": \"#001c37\",\n                        \"outline-variant\": \"#c3c6cf\",\n                        \"secondary-fixed-dim\": \"#88d982\",\n                        \"surface-container-lowest\": \"#ffffff\",\n                        \"on-error-container\": \"#93000a\",\n                        \"secondary\": \"#1b6d24\",\n                        \"primary-container\": \"#1a3a5c\",\n                        \"inverse-primary\": \"#abc9f2\",\n                        \"on-secondary-container\": \"#217128\",\n                        \"surface-container-low\": \"#f5f3f3\",\n                        \"error-container\": \"#ffdad6\",\n                        \"on-secondary-fixed\": \"#002204\",\n                        \"surface-bright\": \"#fbf9f9\",\n                        \"on-primary-fixed-variant\": \"#2a486b\",\n                        \"surface-dim\": \"#dbdada\",\n                        \"surface-variant\": \"#e4e2e2\",\n                        \"primary-fixed\": \"#d2e4ff\",\n                        \"surface-container\": \"#efeded\",\n                        \"on-surface-variant\": \"#43474e\",\n                        \"on-secondary\": \"#ffffff\",\n                        \"outline\": \"#73777f\",\n                        \"surface-tint\": \"#436084\",\n                        \"tertiary-fixed-dim\": \"#ffb691\",\n                        \"secondary-fixed\": \"#a3f69c\",\n                        \"on-primary\": \"#ffffff\",\n                        \"secondary-container\": \"#a0f399\",\n                        \"on-background\": \"#1b1c1c\",\n                        \"primary\": \"#002444\",\n                        \"on-surface\": \"#1b1c1c\",\n                        \"surface-container-high\": \"#e9e8e8\",\n                        \"background\": \"#fbf9f9\",\n                        \"on-primary-container\": \"#87a4cc\",\n                        \"on-tertiary\": \"#ffffff\",\n                        \"on-tertiary-fixed\": \"#341100\",\n                        \"tertiary\": \"#401600\",\n                        \"on-tertiary-container\": \"#ff7c2e\",\n                        \"primary-fixed-dim\": \"#abc9f2\",\n                        \"surface-container-highest\": \"#e4e2e2\",\n                        \"surface\": \"#fbf9f9\",\n                        \"on-error\": \"#ffffff\"\n                    },\n                    borderRadius: {\n                        \"DEFAULT\": \"0.125rem\",\n                        \"lg\": \"0.25rem\",\n                        \"xl\": \"0.5rem\",\n                        \"full\": \"0.75rem\"\n                    },\n                    fontFamily: {\n                        \"headline\": [\"Public Sans\", \"Noto Sans KR\"],\n                        \"body\": [\"Noto Sans KR\", \"sans-serif\"],\n                        \"label\": [\"Public Sans\", \"Noto Sans KR\"]\n                    }\n                }\n            }\n        }\n    </script>\n<style>\n        body { font-family: 'Noto Sans KR', sans-serif; word-break: keep-all; }\n        .material-symbols-outlined { font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24; }\n        .glass-nav { background: rgba(251, 249, 249, 0.85); backdrop-filter: blur(12px); }\n        .editorial-shadow { box-shadow: 0 20px 40px rgba(27, 28, 28, 0.06); }\n    </style>\n</head>\n<body class=\"bg-background text-on-surface\">\n<!-- Top Navigation Shell -->\n<nav class=\"fixed top-0 left-0 right-0 z-50 glass-nav border-b border-outline-variant/10\">\n<div class=\"flex justify-between items-center w-full px-8 py-4 max-w-7xl mx-auto\">\n<div class=\"text-2xl font-bold text-primary tracking-tighter\">\n                Urban Safety Design Center\n            </div>\n<div class=\"hidden md:flex items-center gap-10\">\n<a class=\"text-primary font-bold border-b-2 border-primary pb-1 font-body\" href=\"#\">Our Legacy</a>\n<a class=\"text-on-surface-variant hover:text-primary transition-colors duration-300 font-body\" href=\"#\">Safety Data</a>\n<a class=\"text-on-surface-variant hover:text-primary transition-colors duration-300 font-body\" href=\"#\">Programs</a>\n<a class=\"text-on-surface-variant hover:text-primary transition-colors duration-300 font-body\" href=\"#\">News</a>\n<a class=\"text-on-surface-variant hover:text-primary transition-colors duration-300 font-body\" href=\"#\">Resources</a>\n</div>\n<button class=\"bg-primary text-white px-6 py-2 rounded-md font-medium text-sm hover:bg-primary-container transition-all duration-300 min-h-[48px]\">\n                Certificate Inquiry\n            </button>\n</div>\n</nav>\n<main class=\"pt-[80px]\">\n<!-- Hero Section: The Architectural Archive -->\n<section class=\"relative h-[720px] flex items-center overflow-hidden\">\n<div class=\"absolute inset-0 z-0\">\n<img class=\"w-full h-full object-cover\" data-alt=\"Modern architectural cityscape with clean lines and safe pedestrian zones at dawn with deep blue and soft gold lighting\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuDqvpcusTFMsXuJTMrjlYhzrr4j8mEtJYkAtqHi916Six6OjbkjDSLwg1nrUyltpBpXZ_OqXcPClWLJQYlNk93kYw_tjoRMb9Mnhogy9kjcQyXwS3m3-1CTebpm5Z_PNRPT2ksCusI4Ngk845-nMYdm-fSKiE8hr12BSQLcW0Qx4K9eYNyxX4k3xgrZSqtsGrdcPsZAHFbBkE51CgMOaYn7fxm4SQZ5ubbZvSQ2R9Um5fzkkF8QG7uFMBIKV21fzdVlLjYJPsuoflE\"/>\n<div class=\"absolute inset-0 bg-gradient-to-tr from-primary via-primary/80 to-transparent\"></div>\n</div>\n<div class=\"relative z-10 max-w-7xl mx-auto px-8 w-full\">\n<div class=\"max-w-2xl text-white\">\n<span class=\"inline-block py-1 px-3 bg-secondary mb-6 text-sm font-bold tracking-widest uppercase rounded\">35 Years of Excellence</span>\n<h1 class=\"text-[56px] leading-[1.1] font-bold mb-8 font-headline tracking-tight\">\n                        Building a Legacy of<br/>Urban Safety &amp; Trust\n                    </h1>\n<p class=\"text-lg leading-relaxed mb-10 text-primary-fixed opacity-90 max-w-lg\">\n                        Since 1989, we have partnered with civil society to design safer cities. Through expert education and rigorous data, we ensure every urban space serves its citizens securely.\n                    </p>\n<div class=\"flex gap-4\">\n<button class=\"bg-secondary text-white px-8 py-4 rounded-md font-bold text-lg min-h-[56px] hover:bg-on-secondary-container transition-all shadow-lg\">\n                            Explore Safety Programs\n                        </button>\n<button class=\"bg-white/10 backdrop-blur-md border border-white/20 text-white px-8 py-4 rounded-md font-bold text-lg min-h-[56px] hover:bg-white/20 transition-all\">\n                            View 2024 Data Report\n                        </button>\n</div>\n</div>\n</div>\n</section>\n<!-- Value Cards: Tonal Layering -->\n<section class=\"py-24 bg-surface-container-low\">\n<div class=\"max-w-7xl mx-auto px-8\">\n<div class=\"grid grid-cols-1 md:grid-cols-3 gap-8\">\n<!-- Card 1 -->\n<div class=\"bg-surface-container-lowest p-10 rounded-xl editorial-shadow group hover:-translate-y-2 transition-transform duration-500\">\n<div class=\"w-16 h-16 bg-primary-container rounded-full flex items-center justify-center mb-8 text-on-primary-container group-hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-4xl\" data-icon=\"policy\">policy</span>\n</div>\n<h3 class=\"text-2xl font-bold mb-4 text-primary\">Public Safety Standards</h3>\n<p class=\"text-on-surface-variant text-lg leading-relaxed\">\n                            Developing rigorous urban safety design guidelines that serve as the foundation for institutional credentials.\n                        </p>\n</div>\n<!-- Card 2 -->\n<div class=\"bg-surface-container-lowest p-10 rounded-xl editorial-shadow group hover:-translate-y-2 transition-transform duration-500\">\n<div class=\"w-16 h-16 bg-secondary-container rounded-full flex items-center justify-center mb-8 text-on-secondary-container group-hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-4xl\" data-icon=\"school\">school</span>\n</div>\n<h3 class=\"text-2xl font-bold mb-4 text-primary\">Expert Qualification</h3>\n<p class=\"text-on-surface-variant text-lg leading-relaxed\">\n                            Certified training programs designed to cultivate the next generation of urban safety design specialists.\n                        </p>\n</div>\n<!-- Card 3 -->\n<div class=\"bg-surface-container-lowest p-10 rounded-xl editorial-shadow group hover:-translate-y-2 transition-transform duration-500\">\n<div class=\"w-16 h-16 bg-tertiary-fixed rounded-full flex items-center justify-center mb-8 text-on-tertiary-fixed-variant group-hover:scale-110 transition-transform\">\n<span class=\"material-symbols-outlined text-4xl\" data-icon=\"query_stats\">query_stats</span>\n</div>\n<h3 class=\"text-2xl font-bold mb-4 text-primary\">Civic Data Advocacy</h3>\n<p class=\"text-on-surface-variant text-lg leading-relaxed\">\n                            Transforming complex urban data into actionable insights for safer, more inclusive neighborhood designs.\n                        </p>\n</div>\n</div>\n</div>\n</section>\n<!-- Flagship Programs: Asymmetric Layout -->\n<section class=\"py-24\">\n<div class=\"max-w-7xl mx-auto px-8\">\n<div class=\"flex flex-col md:flex-row gap-12 items-stretch\">\n<!-- Program 1 -->\n<div class=\"flex-1 bg-secondary rounded-2xl p-12 text-white relative overflow-hidden\">\n<div class=\"absolute top-0 right-0 p-8 opacity-10\">\n<span class=\"material-symbols-outlined text-[120px]\" data-icon=\"security\">security</span>\n</div>\n<h4 class=\"text-label uppercase tracking-widest font-bold mb-4 text-secondary-fixed\">Department of Education</h4>\n<h2 class=\"text-4xl font-bold mb-8\">Life Safety Academy</h2>\n<ul class=\"space-y-6 mb-12\">\n<li class=\"flex items-start gap-4\">\n<span class=\"material-symbols-outlined text-secondary-fixed mt-1\" data-icon=\"check_circle\">check_circle</span>\n<span class=\"text-lg opacity-90\">Community safety leadership development</span>\n</li>\n<li class=\"flex items-start gap-4\">\n<span class=\"material-symbols-outlined text-secondary-fixed mt-1\" data-icon=\"check_circle\">check_circle</span>\n<span class=\"text-lg opacity-90\">Citizen-led safety auditing techniques</span>\n</li>\n<li class=\"flex items-start gap-4\">\n<span class=\"material-symbols-outlined text-secondary-fixed mt-1\" data-icon=\"check_circle\">check_circle</span>\n<span class=\"text-lg opacity-90\">Urban disaster prevention protocols</span>\n</li>\n</ul>\n<button class=\"bg-white text-secondary px-8 py-3 rounded-md font-bold text-lg min-h-[48px] hover:bg-surface-container transition-colors\">\n                            Enroll in Academy\n                        </button>\n</div>\n<!-- Program 2 -->\n<div class=\"flex-1 bg-primary-container rounded-2xl p-12 text-white relative overflow-hidden\">\n<div class=\"absolute top-0 right-0 p-8 opacity-10\">\n<span class=\"material-symbols-outlined text-[120px]\" data-icon=\"architecture\">architecture</span>\n</div>\n<h4 class=\"text-label uppercase tracking-widest font-bold mb-4 text-on-primary-container\">Certification Center</h4>\n<h2 class=\"text-4xl font-bold mb-8\">Urban Safety Design Expert</h2>\n<ul class=\"space-y-6 mb-12\">\n<li class=\"flex items-start gap-4\">\n<span class=\"material-symbols-outlined text-primary-fixed mt-1\" data-icon=\"verified\">verified</span>\n<span class=\"text-lg opacity-90\">CPTED advanced technical curriculum</span>\n</li>\n<li class=\"flex items-start gap-4\">\n<span class=\"material-symbols-outlined text-primary-fixed mt-1\" data-icon=\"verified\">verified</span>\n<span class=\"text-lg opacity-90\">Professional licensure examination prep</span>\n</li>\n<li class=\"flex items-start gap-4\">\n<span class=\"material-symbols-outlined text-primary-fixed mt-1\" data-icon=\"verified\">verified</span>\n<span class=\"text-lg opacity-90\">Public infrastructure audit practicum</span>\n</li>\n</ul>\n<button class=\"bg-white text-primary px-8 py-3 rounded-md font-bold text-lg min-h-[48px] hover:bg-surface-container transition-colors\">\n                            Apply for Course\n                        </button>\n</div>\n</div>\n</div>\n</section>\n<!-- News/Board: Editorial Feed -->\n<section class=\"py-24 bg-surface-container-low\">\n<div class=\"max-w-7xl mx-auto px-8\">\n<div class=\"flex justify-between items-end mb-12\">\n<div>\n<h2 class=\"text-3xl font-bold text-primary mb-2\">Notice &amp; Insight Archive</h2>\n<div class=\"w-20 h-1 bg-secondary\"></div>\n</div>\n<a class=\"text-primary font-bold flex items-center gap-2 hover:underline\" href=\"#\">\n                        View All Records <span class=\"material-symbols-outlined\">arrow_forward</span>\n</a>\n</div>\n<div class=\"grid grid-cols-1 lg:grid-cols-2 gap-12\">\n<!-- Primary News Item -->\n<div class=\"bg-surface-container-lowest p-8 rounded-xl editorial-shadow flex flex-col justify-between\">\n<div>\n<span class=\"text-secondary font-bold text-sm mb-4 block\">INSTITUTIONAL ANNOUNCEMENT</span>\n<h3 class=\"text-2xl font-bold text-on-surface mb-6 leading-snug\">\n                                CCEJ Celebrates 35 Years of Civic Safety Leadership: 2024 Commemorative Forum\n                            </h3>\n<p class=\"text-on-surface-variant text-lg mb-8 line-clamp-3\">\n                                We are hosting a national forum to discuss the future of urban safety design in an aging society, featuring leading architects and policy makers.\n                            </p>\n</div>\n<div class=\"flex justify-between items-center pt-6 border-t border-surface-variant\">\n<span class=\"text-on-surface-variant\">2024.05.21</span>\n<span class=\"material-symbols-outlined text-primary\" data-icon=\"open_in_new\">open_in_new</span>\n</div>\n</div>\n<!-- Secondary List -->\n<div class=\"space-y-4\">\n<div class=\"bg-white p-6 rounded-lg flex items-center gap-6 border-l-4 border-secondary hover:shadow-md transition-shadow\">\n<div class=\"text-center min-w-[60px]\">\n<span class=\"block text-xl font-bold text-primary\">18</span>\n<span class=\"text-xs text-on-surface-variant uppercase\">MAY</span>\n</div>\n<div>\n<h4 class=\"font-bold text-on-surface text-lg hover:text-secondary cursor-pointer\">Registration for Urban Safety Design Expert Course (Phase 2)</h4>\n<span class=\"text-sm text-on-surface-variant\">Technical Training / Certification</span>\n</div>\n</div>\n<div class=\"bg-white p-6 rounded-lg flex items-center gap-6 border-l-4 border-primary-container hover:shadow-md transition-shadow\">\n<div class=\"text-center min-w-[60px]\">\n<span class=\"block text-xl font-bold text-primary\">12</span>\n<span class=\"text-xs text-on-surface-variant uppercase\">MAY</span>\n</div>\n<div>\n<h4 class=\"font-bold text-on-surface text-lg hover:text-secondary cursor-pointer\">Updated CPTED Guidelines for Residential Re-development</h4>\n<span class=\"text-sm text-on-surface-variant\">Safety Resources / Policy</span>\n</div>\n</div>\n<div class=\"bg-white p-6 rounded-lg flex items-center gap-6 border-l-4 border-primary-container hover:shadow-md transition-shadow\">\n<div class=\"text-center min-w-[60px]\">\n<span class=\"block text-xl font-bold text-primary\">05</span>\n<span class=\"text-xs text-on-surface-variant uppercase\">MAY</span>\n</div>\n<div>\n<h4 class=\"font-bold text-on-surface text-lg hover:text-secondary cursor-pointer\">Official Statement on Public Park Safety Standards</h4>\n<span class=\"text-sm text-on-surface-variant\">Institutional News</span>\n</div>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Consultation & Contact -->\n<section class=\"py-24\">\n<div class=\"max-w-7xl mx-auto px-8\">\n<div class=\"bg-primary rounded-2xl p-16 flex flex-col md:flex-row items-center justify-between relative overflow-hidden\">\n<div class=\"absolute inset-0 opacity-10\">\n<img class=\"w-full h-full object-cover\" data-alt=\"Abstract architectural lines forming a geometric mesh representing interconnected urban systems\" src=\"https://lh3.googleusercontent.com/aida-public/AB6AXuAVxqbYLMR5ACgFnHpN36uxGSGStRFFaS7Hfb9HfXJ8XDlFfSKm44e91tQ4sofqa8jvUk8uVBgSWqQoA76bD8xSV-bXqSGCzc6IHZHVSOBbSrP_i_4U9-8J0il5i9LZJ7poNEeUquPZ3LJDf31bdDpsN5Kl1uinFiNQ8xYjPVnMhyY9_YLEi-C6gQW7U-_iHm9A8nl41jtsc2vsEIgX5ZreYi8YYTJsqz6r6ar0-VCOD-TL1n3SqjtAgqqMxEdJR23L1ZFkF-GhN4s\"/>\n</div>\n<div class=\"relative z-10 text-white mb-8 md:mb-0\">\n<h2 class=\"text-3xl font-bold mb-4\">Institutional &amp; Private Consultation</h2>\n<p class=\"text-primary-fixed text-lg opacity-80 mb-0\">Professional safety audits and educational inquiries are processed daily.</p>\n</div>\n<div class=\"relative z-10 text-right\">\n<span class=\"text-secondary-fixed text-sm font-bold tracking-widest block mb-2\">DIRECT INQUIRY</span>\n<div class=\"text-[40px] font-bold text-white mb-6 font-headline\">02-763-0694</div>\n<div class=\"flex gap-4 justify-end\">\n<button class=\"bg-secondary text-white px-8 py-4 rounded-md font-bold hover:bg-on-secondary-container transition-all\">Online Inquiry</button>\n<button class=\"bg-white/10 backdrop-blur-md border border-white/20 text-white px-8 py-4 rounded-md font-bold hover:bg-white/20 transition-all\">Location Info</button>\n</div>\n</div>\n</div>\n</div>\n</section>\n<!-- Partnership Strip -->\n<section class=\"py-12 bg-white\">\n<div class=\"max-w-7xl mx-auto px-8 text-center\">\n<h5 class=\"text-on-surface-variant text-sm font-bold uppercase tracking-widest mb-10\">Partnering Institutions for a Safer Society</h5>\n<div class=\"flex flex-wrap justify-center items-center gap-16 grayscale opacity-60\">\n<span class=\"text-2xl font-bold font-headline\">GOV_METRO</span>\n<span class=\"text-2xl font-bold font-headline\">ARCH_ASSOC</span>\n<span class=\"text-2xl font-bold font-headline\">CIVIC_NETWORK</span>\n<span class=\"text-2xl font-bold font-headline\">SAFETY_INST</span>\n<span class=\"text-2xl font-bold font-headline\">TRUST_KOREA</span>\n</div>\n</div>\n</section>\n</main>\n<!-- Safety Notice Banner -->\n<div class=\"bg-tertiary-container text-tertiary-fixed py-2 px-8 text-center text-sm font-medium border-b border-tertiary\">\n        Notice: The Urban Safety Design Expert certification is a recognized private qualification (Registration No. 2014-4122) under civil society governance.\n    </div>\n<!-- Footer: The Trust Seal -->\n<footer class=\"bg-primary-container text-white py-16 px-8 border-t-4 border-tertiary-container\">\n<div class=\"max-w-7xl mx-auto\">\n<div class=\"flex flex-col md:flex-row justify-between items-start gap-12 mb-12\">\n<div class=\"max-w-sm\">\n<div class=\"text-2xl font-bold text-white mb-6\">CCEJ Urban Safety Design Center</div>\n<p class=\"text-on-primary-container text-lg leading-relaxed mb-6\">\n                        Dedicated to the pursuit of civic excellence and urban integrity through architectural safety design since 1989.\n                    </p>\n<div class=\"flex gap-4\">\n<span class=\"material-symbols-outlined text-on-primary-container\" data-icon=\"facebook\">social_leaderboard</span>\n<span class=\"material-symbols-outlined text-on-primary-container\" data-icon=\"share\">share</span>\n<span class=\"material-symbols-outlined text-on-primary-container\" data-icon=\"info\">info</span>\n</div>\n</div>\n<div class=\"grid grid-cols-2 md:grid-cols-3 gap-12\">\n<div>\n<h6 class=\"font-bold mb-6 text-on-primary-container uppercase tracking-wide\">Governance</h6>\n<ul class=\"space-y-3\">\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Privacy Policy</a></li>\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Terms of Service</a></li>\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Ethics Charter</a></li>\n</ul>\n</div>\n<div>\n<h6 class=\"font-bold mb-6 text-on-primary-container uppercase tracking-wide\">Resources</h6>\n<ul class=\"space-y-3\">\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Safety Standards</a></li>\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Data Archive</a></li>\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Publications</a></li>\n</ul>\n</div>\n<div>\n<h6 class=\"font-bold mb-6 text-on-primary-container uppercase tracking-wide\">Institutional</h6>\n<ul class=\"space-y-3\">\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Credentials</a></li>\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Board Minutes</a></li>\n<li><a class=\"text-primary-fixed hover:text-white transition-colors\" href=\"#\">Contact</a></li>\n</ul>\n</div>\n</div>\n</div>\n<div class=\"pt-8 border-t border-on-primary-container/20 flex flex-col md:flex-row justify-between items-center gap-4\">\n<div class=\"text-on-primary-container text-sm\">\n                    © 1989-2024 CCEJ Urban Safety Design Center. 35 Years of Civic Excellence.\n                </div>\n<div class=\"flex gap-8 text-sm font-bold text-on-primary-container\">\n<span>TEL: 02-763-0694</span>\n<span>FAX: 02-764-0136</span>\n<span>EMAIL: safety@ccej.or.kr</span>\n</div>\n</div>\n</div>\n</footer>\n</body></html>"}
